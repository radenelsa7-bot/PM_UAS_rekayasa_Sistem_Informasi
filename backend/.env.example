APP_NAME=db_schema_tukangdekat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_tukangdekat
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
FORCE_HTTPS=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use non-DB drivers for quick local testing
# Use database-backed drivers (original setup)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAYMENT_GATEWAY_DRIVER=midtrans
# Use your actual keys here. Keep server key secret and do NOT commit.
MIDTRANS_SERVER_KEY="
MIDTRANS_CLIENT_KEY="
MIDTRANS_IS_PRODUCTION=false
# Xendit keys (development/sandbox secret key). Keep secret; do NOT commit real production keys.
XENDIT_DISBURSEMENT_PATH="/payouts"
XENDIT_API_KEY=
XENDIT_BASE_URL=
XENDIT_DEBUG=0
PAYOUT_GATEWAY=mock
PAYOUT_MAX_ATTEMPTS=3
PAYOUT_ALERT_WEBHOOK=
PAYOUT_ALERT_EMAIL=

# n8n integration
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_EVENT_SECRET=
