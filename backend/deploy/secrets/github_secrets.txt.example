# Contoh file untuk `set_github_secrets.sh` (KEY=VALUE per baris)
# Salin file ini menjadi `github_secrets.txt`, isi nilai placeholder dengan nilai nyata, lalu jalankan skrip:
# ./deploy/set_github_secrets.sh <owner> <repo> deploy/secrets/github_secrets.txt

# Payout / Payment
XENDIT_API_KEY=sk_test_xnd_example_key
MIDTRANS_SERVER_KEY=midtrans_test_server_key_example
MIDTRANS_WEBHOOK_KEY=midtrans_webhook_key_example
PAYOUT_GATEWAY=xendit

# Deploy / Host
DEPLOY_HOST=app.example.com
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/tukangdekat/backend
DEPLOY_KEY=-----BEGIN PRIVATE KEY-----\n...replace_with_private_key...\n-----END PRIVATE KEY-----

# Alerts
PAYOUT_ALERT_EMAIL=ops@example.com
PAYOUT_ALERT_WEBHOOK=https://hooks.example.com/payout-alerts

# App / Env
APP_ENV=production
APP_KEY=base64:replace_app_key_here

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tukangdekat
DB_USERNAME=dbuser
DB_PASSWORD=dbpassword

# NOTE: Jangan commit file ini dengan nilai nyata. Gunakan hanya untuk contoh/template.
